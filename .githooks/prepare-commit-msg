#!/usr/bin/env bash
# Append the current build version to the commit subject.
#
# build.ps1 writes the latest stamp to <repo-root>/version.txt — either the dev shape
# YYYY.M.D.N-XXXX (the common case for local builds) or the release shape YYYY.M.D.N
# (no suffix; only when a release tag drives the build). This hook tacks the stamp onto
# the subject in parens so `git log` shows which build a commit corresponds to without
# needing to map hashes by hand.
#
# Companion hook commit-msg rejects duplicate stamps if an editor template
# autocompletes a stale one; keep these two in sync.
#
# Skip merge/squash messages — those already include structured content and the
# stamp adds noise. --no-verify bypasses if you really need to.

set -eu

msg_file="$1"
source="${2:-}"

case "$source" in
  merge|squash) exit 0 ;;
esac

# Refuse to silently double-stamp when something else (an editor template, a copy
# from "git log", an agent that "matched repo style") already put a build-version
# stamp into the subject. The hook is the single source of truth for stamps:
# don't pre-stamp; let this hook tack version.txt onto the subject. For amends
# the subject already has yesterday's stamp; "commit" source means amend/reword
# and is allowed through without re-checking (and without re-adding).
if [ "$source" != "commit" ]; then
  subject="$(grep -m1 -vE '^(#|$)' "$msg_file" || true)"
  if printf '%s\n' "$subject" \
      | grep -qE '\([0-9]{4}\.[0-9]+\.[0-9]+\.[0-9]+(-[A-Fa-f0-9]{4})?\)'; then
    echo "" >&2
    echo "prepare-commit-msg: subject already contains a build-version stamp." >&2
    echo "" >&2
    echo "  subject: $subject" >&2
    echo "" >&2
    echo "Don't pre-stamp commit subjects: this hook reads version.txt and appends" >&2
    echo "the current stamp. Stamps you copy from 'git log' or an editor template" >&2
    echo "are almost always stale by the time the next build runs. Drop the (YYYY.M.D.N...)" >&2
    echo "trailer from the subject and commit again." >&2
    echo "" >&2
    exit 1
  fi
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[ -n "$repo_root" ] || exit 0

version_file="$repo_root/version.txt"
[ -f "$version_file" ] || exit 0

# Strip BOM/non-printables and trim — version.txt is written by PowerShell on Windows
# and can carry a UTF-8 BOM that breaks the grep below.
version="$(tr -d '\r' < "$version_file" | sed 's/[^[:print:]]//g' | xargs)"
[ -n "$version" ] || exit 0

# Append only if the subject is clean (no version stamp of any vintage). The
# old behaviour was a literal "($version)" check, which appended whenever the
# subject held a stamp from a different build than the current version.txt --
# exactly the path that produced the 2026-05-12 double-stamp run when a fresh
# build's stamp hit a subject that already carried yesterday's stamp.
if ! grep -qE '\([0-9]{4}\.[0-9]+\.[0-9]+\.[0-9]+(-[A-Fa-f0-9]{4})?\)' "$msg_file"; then
  sed -i "1s/\$/ ($version)/" "$msg_file"
fi
